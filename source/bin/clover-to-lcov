#!/usr/bin/env php
<?php

/**
 * Converts a PHPUnit Clover XML coverage report to LCOV format.
 *
 * Usage: php bin/clover-to-lcov <clover.xml> <lcov.info>
 */

if ($argc !== 3) {
    fwrite(STDERR, "Usage: {$argv[0]} <clover.xml> <lcov.info>\n");
    exit(1);
}

$cloverFile = $argv[1];
$lcovFile   = $argv[2];

if (!file_exists($cloverFile)) {
    fwrite(STDERR, "Error: Clover file not found: {$cloverFile}\n");
    exit(1);
}

$xml = simplexml_load_file($cloverFile);
if ($xml === false) {
    fwrite(STDERR, "Error: Failed to parse Clover XML: {$cloverFile}\n");
    exit(1);
}

$lcov = '';

foreach ($xml->project->file as $file) {
    $filename = (string) $file['name'];

    $lcov .= "SF:{$filename}\n";

    $linesFound = 0;
    $linesHit   = 0;

    foreach ($file->line as $line) {
        if ((string) $line['type'] !== 'stmt') {
            continue;
        }

        $lineNum = (int) $line['num'];
        $count   = (int) $line['count'];

        $lcov .= "DA:{$lineNum},{$count}\n";
        $linesFound++;
        if ($count > 0) {
            $linesHit++;
        }
    }

    $lcov .= "LF:{$linesFound}\n";
    $lcov .= "LH:{$linesHit}\n";
    $lcov .= "end_of_record\n";
}

$dir = dirname($lcovFile);
if (!is_dir($dir)) {
    mkdir($dir, 0755, true);
}

file_put_contents($lcovFile, $lcov);
echo "LCOV report written to {$lcovFile}\n";
